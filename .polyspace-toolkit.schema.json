{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Personal Polyspace Toolkit project configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "language", "profiles", "checkersFile"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "language": { "const": "c" },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["misra-c-2012", "misra-c-2023", "cert-c", "cwe", "polyspace-defects", "custom"]
      }
    },
    "checkersFile": { "$ref": "#/$defs/path" },
    "buildOptionsFile": { "$ref": "#/$defs/path" },
    "analysisOptionsFile": { "$ref": "#/$defs/path" },
    "justificationCatalog": { "$ref": "#/$defs/path" },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use": { "$ref": "#/$defs/path" },
        "store": { "$ref": "#/$defs/path" }
      }
    },
    "include": {
      "type": "array",
      "items": { "type": "string", "pattern": "\\.c$" }
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "path": { "type": "string", "minLength": 1 }
  }
}
